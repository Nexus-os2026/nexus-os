<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="NEXUS OS"
    Language="1033"
    Version="1.0.0.0"
    Manufacturer="NEXUS OS"
    UpgradeCode="D8EADECC-0000-4E86-92F0-4EE2FD6626A1">

    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of NEXUS OS is already installed." />

    <Feature Id="MainFeature" Title="NEXUS OS" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="NEXUS OS" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="NexusCliComponent" Guid="E42E11E2-6B4E-4124-A883-02771820A0E8">
        <File Id="NexusCliExe" Source="target/release/nexus-cli.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
