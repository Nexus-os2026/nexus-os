# Nexus OS Environment Variables

# LLM Provider Selection
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434

# API Keys (set the ones you want to use)
GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
PERPLEXITY_API_KEY=
COHERE_API_KEY=
OPENROUTER_API_KEY=

# Flash Inference
FLASH_MODEL_PATH=

# Database
NEXUS_DB_PATH=data/nexus.db

# External Tools
GITHUB_TOKEN=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_TOKEN=
SLACK_TOKEN=
SMTP_HOST=
SMTP_FROM=
SMTP_PASSWORD=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
DATABASE_URL=

# Messaging (optional)
NEXUS_MESSAGING_ENABLED=false
NEXUS_GMAIL_CLIENT_ID=
NEXUS_GMAIL_CLIENT_SECRET=
NEXUS_OUTLOOK_CLIENT_ID=
NEXUS_OUTLOOK_CLIENT_SECRET=
