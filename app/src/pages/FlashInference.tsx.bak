import { useState, useEffect, useCallback, useRef } from "react";
import { Zap, Send, Square, Trash2, AlertTriangle, X } from "lucide-react";
import {
  flashDetectHardware,
  flashCreateSession,
  flashUnloadSession,
  flashGetMetrics,
  flashGenerate,
  flashListLocalModels,
  flashAvailableDiskSpace,
} from "../api/backend";
import "./flash-inference.css";

/* ── types ── */

interface HwInfo {
  total_ram_mb: number;
  available_ram_mb: number;
  cpu_cores: number;
  cpu_model: string;
  ssd_type: string;
  ssd_read_mb_per_sec: number;
}

interface BackendMetrics {
  session_id: string;
  memory_used_mb: number;
  memory_budget_mb: number;
  context_used: number;
  context_max: number;
  total_tokens_generated: number;
}

interface ChatMsg {
  role: "user" | "assistant";
  content: string;
}

interface LocalModel {
  name: string;
  file_path: string;
  file_size_bytes: number;
  file_size_display: string;
  quant_type: string;
}

/* ── helpers ── */

const HISTORY_KEY = "flash-chat-history";
const HISTORY_LIMIT = 100;

function loadHistory(): ChatMsg[] {
  try {
    const raw = localStorage.getItem(HISTORY_KEY);
    if (!raw) return [];
    const parsed: ChatMsg[] = JSON.parse(raw);
    return parsed.slice(-HISTORY_LIMIT);
  } catch {
    return [];
  }
}

function saveHistory(msgs: ChatMsg[]): void {
  try {
    localStorage.setItem(HISTORY_KEY, JSON.stringify(msgs.slice(-HISTORY_LIMIT)));
  } catch {
    /* quota exceeded */
  }
}

function fmtMb(mb: number): string {
  if (!isFinite(mb) || mb < 0) return "0 MB";
  if (mb >= 1024) return `${(mb / 1024).toFixed(1)} GB`;
  return `${Math.round(mb)} MB`;
}

function fmtBytes(bytes: number): string {
  if (!isFinite(bytes) || bytes < 0) return "0 B";
  if (bytes >= 1_073_741_824) return `${(bytes / 1_073_741_824).toFixed(1)} GB`;
  if (bytes >= 1_048_576) return `${(bytes / 1_048_576).toFixed(1)} MB`;
  return `${(bytes / 1024).toFixed(0)} KB`;
}

/* ── component ── */

export default function FlashInference(): JSX.Element {
  /* hardware */
  const [hw, setHw] = useState<HwInfo | null>(null);
  const [diskSpace, setDiskSpace] = useState<number | null>(null);

  /* models */
  const [localModels, setLocalModels] = useState<LocalModel[]>([]);
  const [selectedIdx, setSelectedIdx] = useState(0);

  /* session */
  const [sessionId, setSessionId] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(false);
  const [loadedModelName, setLoadedModelName] = useState("");

  /* chat */
  const [messages, setMessages] = useState<ChatMsg[]>(loadHistory);
  const [draft, setDraft] = useState("");
  const [isGenerating, setIsGenerating] = useState(false);
  const [streamingText, setStreamingText] = useState("");
  const chatEndRef = useRef<HTMLDivElement>(null);
  const inputRef = useRef<HTMLInputElement>(null);
  const scrollRafRef = useRef<number | null>(null);
  const userScrolledRef = useRef(false);

  /* frontend metrics — calculated from streaming events */
  const genStartRef = useRef(0);
  const tokenCountRef = useRef(0);
  const [tokPerSec, setTokPerSec] = useState(0);
  const [tokenCount, setTokenCount] = useState(0);
  const [lastTokPerSec, setLastTokPerSec] = useState(0);
  const [lastTokenCount, setLastTokenCount] = useState(0);

  /* backend metrics (memory, context) */
  const [metrics, setMetrics] = useState<BackendMetrics | null>(null);
  const metricsRef = useRef<ReturnType<typeof setInterval> | null>(null);

  /* error */
  const [error, setError] = useState<string | null>(null);

  /* ── init: hardware + models ── */
  useEffect(() => {
    let cancelled = false;
    (async () => {
      try {
        const info = await flashDetectHardware();
        if (!cancelled) setHw(info);
      } catch {
        if (!cancelled)
          setHw({
            total_ram_mb: 0, available_ram_mb: 0,
            cpu_cores: navigator.hardwareConcurrency || 0,
            cpu_model: "Unknown", ssd_type: "Unknown", ssd_read_mb_per_sec: 0,
          });
      }
    })();
    return () => { cancelled = true; };
  }, []);

  const refreshModels = useCallback(async () => {
    try {
      const [models, space] = await Promise.all([
        flashListLocalModels(), flashAvailableDiskSpace(),
      ]);
      if (Array.isArray(models)) setLocalModels(models);
      if (typeof space === "number") setDiskSpace(space);
    } catch { /* non-critical */ }
  }, []);

  useEffect(() => { refreshModels(); }, [refreshModels]);

  /* ── persist chat ── */
  useEffect(() => { saveHistory(messages); }, [messages]);

  /* ── auto-focus input when model loads ── */
  useEffect(() => { if (sessionId) inputRef.current?.focus(); }, [sessionId]);

  /* ── smart auto-scroll ── */
  const scheduleScroll = useCallback(() => {
    if (scrollRafRef.current || userScrolledRef.current) return;
    scrollRafRef.current = requestAnimationFrame(() => {
      scrollRafRef.current = null;
      chatEndRef.current?.scrollIntoView({ behavior: "smooth" });
    });
  }, []);

  useEffect(() => { scheduleScroll(); }, [messages, streamingText, scheduleScroll]);

  useEffect(() => {
    if (messages.length > 0 && messages[messages.length - 1].role === "user") {
      userScrolledRef.current = false;
    }
  }, [messages]);

  const handleChatScroll = useCallback((e: React.UIEvent<HTMLDivElement>) => {
    const el = e.currentTarget;
    userScrolledRef.current = el.scrollHeight - el.scrollTop - el.clientHeight > 80;
  }, []);

  /* ── backend metrics polling (memory/context only) ── */
  useEffect(() => {
    if (metricsRef.current) { clearInterval(metricsRef.current); metricsRef.current = null; }
    if (!sessionId) { setMetrics(null); return; }
    const poll = async () => {
      try { setMetrics(await flashGetMetrics(sessionId)); } catch { /* */ }
    };
    poll();
    metricsRef.current = setInterval(poll, 3000);
    return () => { if (metricsRef.current) { clearInterval(metricsRef.current); metricsRef.current = null; } };
  }, [sessionId]);

  /* ── streaming events ── */
  useEffect(() => {
    if (!sessionId) return;
    let unToken: (() => void) | undefined;
    let unDone: (() => void) | undefined;
    let unError: (() => void) | undefined;
    (async () => {
      try {
        const ev = await import("@tauri-apps/api/event");
        unToken = await ev.listen<{ text: string }>("flash-token", (e) => {
          setStreamingText((prev) => prev + e.payload.text);
          tokenCountRef.current += 1;
          const elapsed = (performance.now() - genStartRef.current) / 1000;
          const count = tokenCountRef.current;
          setTokenCount(count);
          if (elapsed > 0.1) setTokPerSec(count / elapsed);
        });
        unDone = await ev.listen("flash-done", () => {
          const elapsed = (performance.now() - genStartRef.current) / 1000;
          const count = tokenCountRef.current;
          if (elapsed > 0 && count > 0) {
            setLastTokPerSec(count / elapsed);
            setLastTokenCount(count);
          }
          setTokPerSec(0);
          setTokenCount(0);
          setIsGenerating(false);
          setStreamingText((prev) => {
            if (prev) setMessages((msgs) => [...msgs, { role: "assistant", content: prev }]);
            return "";
          });
        });
        unError = await ev.listen<{ message: string }>("flash-error", (e) => {
          setError(e.payload.message);
          const elapsed = (performance.now() - genStartRef.current) / 1000;
          const count = tokenCountRef.current;
          if (elapsed > 0 && count > 0) {
            setLastTokPerSec(count / elapsed);
            setLastTokenCount(count);
          }
          setTokPerSec(0);
          setTokenCount(0);
          setIsGenerating(false);
          setStreamingText((prev) => {
            if (prev) setMessages((msgs) => [...msgs, { role: "assistant", content: prev }]);
            return "";
          });
        });
      } catch { /* not in Tauri */ }
    })();
    return () => { unToken?.(); unDone?.(); unError?.(); };
  }, [sessionId]);

  /* ── actions ── */
  const handleLoad = useCallback(async () => {
    const model = localModels[selectedIdx];
    if (!model) return;
    setIsLoading(true);
    setError(null);
    try {
      const id = await flashCreateSession(model.file_path, 4096, "balanced");
      setSessionId(id);
      setLoadedModelName(model.name.replace(/\.gguf$/, ""));
    } catch (err) {
      setError(`Failed to load: ${err}`);
    } finally {
      setIsLoading(false);
    }
  }, [localModels, selectedIdx]);

  const handleUnload = useCallback(async () => {
    if (!sessionId) return;
    try {
      await flashUnloadSession(sessionId);
      setSessionId(null);
      setMetrics(null);
      setLoadedModelName("");
      setStreamingText("");
    } catch (err) {
      setError(`Failed to unload: ${err}`);
    }
  }, [sessionId]);

  const handleSend = useCallback(async () => {
    const text = draft.trim();
    if (!text || !sessionId || isGenerating) return;
    setDraft("");
    setMessages((prev) => [...prev, { role: "user", content: text }]);
    setIsGenerating(true);
    setStreamingText("");
    genStartRef.current = performance.now();
    tokenCountRef.current = 0;
    setTokPerSec(0);
    setTokenCount(0);
    try {
      await flashGenerate(sessionId, text);
    } catch (err) {
      setError(`Generation failed: ${err}`);
      setIsGenerating(false);
    }
  }, [draft, sessionId, isGenerating]);

  const handleKeyDown = useCallback((e: React.KeyboardEvent) => {
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); handleSend(); }
  }, [handleSend]);

  /* ── derived values ── */
  const displayTokPerSec = isGenerating && tokPerSec > 0
    ? tokPerSec.toFixed(1)
    : lastTokPerSec > 0
      ? lastTokPerSec.toFixed(1)
      : "—";

  const displayTokens = isGenerating
    ? tokenCount
    : lastTokenCount > 0
      ? lastTokenCount
      : metrics?.total_tokens_generated ?? 0;

  /* ── render ── */
  return (
    <div
      className="flash-page"
      style={{
        flex: 1,
        minHeight: 0,
        display: "flex",
        flexDirection: "column",
        overflow: "hidden",
      }}
    >
      {/* CHILD 1 — Top bar */}
      <div
        style={{
          flexShrink: 0,
          height: 48,
          display: "flex",
          alignItems: "center",
          gap: 8,
          padding: "0 16px",
          background: "#0a1628",
          borderBottom: "1px solid #1e3a5f",
          zIndex: 10,
          position: "relative" as const,
        }}
      >
        <Zap size={16} style={{ color: "var(--nexus-accent)", flexShrink: 0 }} />
        <span style={{ color: "#5eead4", fontSize: 14, fontWeight: 600, marginRight: 12, flexShrink: 0 }}>
          Flash Inference
        </span>

        <span style={{ width: 1, height: 16, background: "rgba(74,247,211,0.12)", flexShrink: 0 }} />

        {/* Hardware info */}
        <span style={{ fontSize: 11, color: "#6b7280", marginLeft: "auto", flexShrink: 0 }}>
          {hw
            ? `${fmtMb(hw.total_ram_mb)} RAM | ${hw.cpu_cores} cores | ${hw.ssd_type}${diskSpace !== null ? ` | ${fmtBytes(diskSpace)} free` : ""}`
            : "Detecting hardware..."}
        </span>

        <span style={{ flex: 1 }} />

        {/* Model selector or active model */}
        {sessionId ? (
          <>
            <Zap size={12} style={{ color: "var(--nexus-accent)", filter: "drop-shadow(0 0 4px rgba(74,247,211,0.6))" }} />
            <span style={{ fontWeight: 600, color: "var(--text-primary)", fontSize: "0.82rem" }}>
              {loadedModelName}
            </span>
            <button
              onClick={handleUnload}
              style={{
                background: "transparent",
                border: "1px solid #f87171",
                color: "#f87171",
                padding: "6px 16px",
                borderRadius: 6,
                fontSize: 12,
                cursor: "pointer",
              }}
            >
              Unload
            </button>
          </>
        ) : (
          <>
            <select
              value={selectedIdx}
              onChange={(e) => setSelectedIdx(Number(e.target.value))}
              disabled={isLoading}
              style={{
                flex: 1,
                maxWidth: 500,
                background: "#0d1117",
                color: "#e5e7eb",
                border: "1px solid #1e3a5f",
                borderRadius: 6,
                padding: "6px 12px",
                fontSize: 13,
              }}
            >
              {localModels.length === 0 ? (
                <option value={0}>No models found</option>
              ) : (
                localModels.map((m, i) => (
                  <option key={m.file_path} value={i}>
                    {m.name.replace(/\.gguf$/, "")} ({m.file_size_display}, {m.quant_type})
                  </option>
                ))
              )}
            </select>
            <button
              onClick={handleLoad}
              disabled={localModels.length === 0 || isLoading}
              style={{
                background: "transparent",
                border: "1px solid #5eead4",
                color: "#5eead4",
                padding: "6px 16px",
                borderRadius: 6,
                fontSize: 12,
                cursor: localModels.length === 0 || isLoading ? "not-allowed" : "pointer",
                opacity: localModels.length === 0 || isLoading ? 0.4 : 1,
              }}
            >
              {isLoading ? "Loading..." : <><Zap size={12} /> Load</>}
            </button>
          </>
        )}
      </div>

      {/* CHILD 2 — Metrics bar */}
      {sessionId && (
        <div
          style={{
            flexShrink: 0,
            height: 28,
            display: "flex",
            alignItems: "center",
            gap: 16,
            padding: "0 16px",
            background: "#060d18",
            borderBottom: "1px solid #1e3a5f",
            fontSize: 11,
            color: "#6b7280",
          }}
        >
          <span style={{ color: "var(--nexus-accent)", fontWeight: 600 }}>
            {displayTokPerSec} tok/s
          </span>
          <span style={{ width: 1, height: 10, background: "rgba(74,247,211,0.12)" }} />
          <span style={{ color: "var(--nexus-accent)" }}>
            {metrics ? `${fmtMb(metrics.memory_used_mb)} / ${fmtMb(metrics.memory_budget_mb)} RAM` : "— RAM"}
          </span>
          <span style={{ width: 1, height: 10, background: "rgba(74,247,211,0.12)" }} />
          <span style={{ color: "var(--nexus-accent)" }}>
            {displayTokens} tokens
          </span>
          <span style={{ width: 1, height: 10, background: "rgba(74,247,211,0.12)" }} />
          <span style={{ color: "var(--nexus-accent)" }}>
            ctx {metrics
              ? `${metrics.context_used.toLocaleString()} / ${metrics.context_max > 0 ? metrics.context_max.toLocaleString() : "—"}`
              : "—"}
          </span>
        </div>
      )}

      {/* Error banner */}
      {error && (
        <div style={{
          flexShrink: 0, display: "flex", alignItems: "center", gap: 8,
          padding: "6px 14px", background: "rgba(255,109,122,0.08)",
          borderBottom: "1px solid rgba(255,109,122,0.15)",
          color: "var(--nexus-danger)", fontSize: "0.8rem",
        }}>
          <AlertTriangle size={14} />
          <span style={{ flex: 1 }}>{error}</span>
          <button onClick={() => setError(null)} style={{
            background: "none", border: "none", color: "var(--nexus-danger)",
            cursor: "pointer", padding: 2, lineHeight: 1,
          }}>
            <X size={14} />
          </button>
        </div>
      )}

      {/* CHILD 3 — Chat area */}
      <div
        onScroll={handleChatScroll}
        style={{
          flex: 1,
          minHeight: 0,
          overflowY: "auto",
          padding: "12px 14px",
          display: "flex",
          flexDirection: "column",
          gap: 10,
        }}
      >
        {/* spacer pushes messages to bottom when few */}
        <div style={{ flex: 1 }} />

        {messages.length === 0 && !streamingText && (
          <div style={{
            display: "flex", flexDirection: "column", alignItems: "center",
            justifyContent: "center", padding: "3rem 0",
            color: "var(--text-muted)", gap: 8,
          }}>
            <Zap size={40} style={{ opacity: 0.2 }} />
            <span style={{ fontSize: "0.88rem" }}>
              {sessionId ? "Model loaded. Type a message to begin." : "Load a model to start chatting."}
            </span>
          </div>
        )}

        {messages.map((msg, i) => (
          <div
            key={i}
            style={{
              alignSelf: msg.role === "user" ? "flex-end" : "flex-start",
              maxWidth: "85%",
              padding: "10px 14px",
              borderRadius: msg.role === "user" ? "12px 12px 3px 12px" : "12px 12px 12px 3px",
              background: msg.role === "user"
                ? "rgba(140,123,255,0.15)"
                : "rgba(74,247,211,0.06)",
              border: `1px solid ${msg.role === "user" ? "rgba(140,123,255,0.2)" : "rgba(74,247,211,0.1)"}`,
              color: "var(--text-primary)",
              fontSize: "0.88rem",
              lineHeight: 1.55,
              whiteSpace: "pre-wrap",
              wordBreak: "break-word",
            }}
          >
            {msg.role === "assistant" && loadedModelName && (
              <div style={{
                fontSize: "0.62rem", color: "var(--nexus-accent)", fontFamily: "var(--font-mono)",
                marginBottom: 4, letterSpacing: "0.04em", textTransform: "uppercase", opacity: 0.7,
              }}>
                {loadedModelName}
              </div>
            )}
            {msg.content}
          </div>
        ))}

        {isGenerating && !streamingText && (
          <div style={{ display: "flex", gap: 4, padding: "8px 0", alignSelf: "flex-start" }}>
            {[0, 1, 2].map((i) => (
              <span key={i} className="flash-typing-dot" style={{ animationDelay: `${i * 0.2}s` }} />
            ))}
          </div>
        )}

        {streamingText && (
          <div style={{
            alignSelf: "flex-start", maxWidth: "85%", padding: "10px 14px",
            borderRadius: "12px 12px 12px 3px",
            background: "rgba(74,247,211,0.06)",
            border: "1px solid rgba(74,247,211,0.1)",
            color: "var(--text-primary)", fontSize: "0.88rem",
            lineHeight: 1.55, whiteSpace: "pre-wrap", wordBreak: "break-word",
            minHeight: "2em",
          }}>
            {loadedModelName && (
              <div style={{
                fontSize: "0.62rem", color: "var(--nexus-accent)", fontFamily: "var(--font-mono)",
                marginBottom: 4, letterSpacing: "0.04em", textTransform: "uppercase", opacity: 0.7,
              }}>
                {loadedModelName}
              </div>
            )}
            {streamingText}
            <span className="flash-cursor" />
          </div>
        )}

        {/* Clear history — subtle, only when there are messages */}
        {messages.length > 0 && !isGenerating && (
          <button
            onClick={() => { setMessages([]); setStreamingText(""); }}
            style={{
              alignSelf: "center", background: "none", border: "none",
              color: "var(--text-muted)", fontSize: "0.68rem", cursor: "pointer",
              padding: "4px 8px", opacity: 0.5,
              display: "flex", alignItems: "center", gap: 4,
            }}
          >
            <Trash2 size={10} /> Clear history
          </button>
        )}

        {/* scroll anchor */}
        <div ref={chatEndRef} />
      </div>

      {/* CHILD 4 — Input row */}
      <div
        style={{
          flexShrink: 0,
          height: 52,
          display: "flex",
          alignItems: "center",
          gap: 8,
          padding: "0 12px",
          borderTop: "1px solid rgba(74,247,211,0.08)",
          background: "rgba(0,0,0,0.2)",
        }}
      >
        <input
          ref={inputRef}
          type="text"
          placeholder={sessionId ? "Type a message..." : "Load a model first..."}
          value={draft}
          onChange={(e) => setDraft(e.target.value)}
          onKeyDown={handleKeyDown}
          disabled={!sessionId || isGenerating}
          style={{
            flex: 1, height: 36, padding: "0 12px",
            background: "rgba(10,18,32,0.8)",
            border: "1px solid rgba(74,247,211,0.12)",
            borderRadius: 8, color: "var(--text-primary)",
            fontFamily: "var(--font-body)", fontSize: "0.88rem",
            outline: "none",
          }}
        />
        {isGenerating ? (
          <button
            onClick={() => setIsGenerating(false)}
            style={{
              height: 36, padding: "0 16px",
              background: "rgba(255,109,122,0.12)",
              border: "1px solid rgba(255,109,122,0.25)",
              borderRadius: 8, color: "var(--nexus-danger)",
              fontWeight: 600, fontSize: "0.82rem", cursor: "pointer",
              display: "flex", alignItems: "center", gap: 5,
            }}
          >
            <Square size={14} /> Stop
          </button>
        ) : (
          <button
            onClick={handleSend}
            disabled={!sessionId || !draft.trim()}
            style={{
              height: 36, padding: "0 16px",
              background: "linear-gradient(135deg, rgba(74,247,211,0.15), rgba(140,123,255,0.15))",
              border: "1px solid rgba(74,247,211,0.25)",
              borderRadius: 8, color: "var(--nexus-accent)",
              fontWeight: 600, fontSize: "0.82rem",
              cursor: !sessionId || !draft.trim() ? "not-allowed" : "pointer",
              opacity: !sessionId || !draft.trim() ? 0.4 : 1,
              display: "flex", alignItems: "center", gap: 5,
            }}
          >
            <Send size={14} /> Send
          </button>
        )}
      </div>
    </div>
  );
}
