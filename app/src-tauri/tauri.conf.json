{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexusOS",
  "version": "7.0.0",
  "identifier": "com.nexus-os.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "features": [
      "tauri-runtime"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "NexusOS — Governed Agent Operating System",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/header.bmp",
        "sidebarImage": "icons/sidebar.bmp"
      }
    },
    "shortDescription": "Governed Agent Operating System",
    "longDescription": "NexusOS — The AI agent OS that proves what it did. Create, manage, and monitor autonomous AI agents with complete governance, audit trails, and voice control."
  }
}
