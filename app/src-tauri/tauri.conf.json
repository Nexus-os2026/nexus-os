{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexusOS",
  "version": "0.13.0",
  "identifier": "com.nexus-os.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NexusOS — Governed Agent Operating System",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": true
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "dmg",
      "appimage",
      "deb",
      "rpm"
    ],
    "shortDescription": "NexusOS governed agent operating system",
    "longDescription": "NexusOS is a governed agent operating system with auditable automation, voice control, and policy-bounded execution.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
