{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NEXUS OS",
  "version": "0.13.0",
  "identifier": "com.nexlang.nexusos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NEXUS OS",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "trayIcon": {
    "iconPath": "icons/32x32.png",
    "iconAsTemplate": false,
    "menuOnLeftClick": true
  }
}
